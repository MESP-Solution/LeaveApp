# Copy to .env and adjust values.

# Server
PORT=3000
NODE_ENV=development

# MySQL (MikroORM)
DB_HOST=localhost
DB_PORT=3306
DB_USER=leaveapp
DB_PASSWORD=leaveapp
DB_NAME=leaveapp
# Set to true for managed MySQL with SSL (e.g. cloud providers)
# DB_SSL=false

# Auth (JWT)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# Swagger (disabled when NODE_ENV=production unless SWAGGER_ENABLED is not false)
# SWAGGER_ENABLED=true
# SWAGGER_PATH=api/docs
# SWAGGER_DESCRIPTION=Leave request management API for small companies

# Email (Resend): see MailService. Pending alerts use each approver’s key to their
# inbox. When a HEAD approves/rejects, the employee email uses the request owner’s
# `smtp_pass`; MANAGER/ADMIN use their own.
MAIL_FROM=onboarding@resend.dev
